# Provider: "azure" or "openai"
PROVIDER=azure

# Azure AI Foundry
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_DEPLOYMENT_NAME=sora-2
# AZURE_CLIENT_ID=  # Only for managed identity on remote deployments

# OpenAI (only needed if PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Server
PORT=3000

# Admin panel (shows all jobs from all users, default: false)
ADMIN_ENABLED=false

# Azure Application Insights (optional — telemetry disabled if not set)
# APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
